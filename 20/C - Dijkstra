int main(){
    //speed();
	map<int,vector<pair<int,int>>> adj;
	int n,m;
	cin>>n>>m;
	int m2=m;
	int a,b;
	ll w;
	while(m2--){
		cin>>a>>b>>w;
		adj[a].pb(make_pair(b,w));
		adj[b].pb(make_pair(a,w));
	}
	priority_queue<pair<ll,int>> pq;
	vector<ll> distance(n+1,LLONG_MAX);
	vector<bool> process(n+1,false);
	pq.push({0,1});
	distance[1]=0;
	vector<int> pre(n+1);
	pre[1]=-1;
	while(!pq.empty()){
		int current = pq.top().second; pq.pop();
		if (process[current]) continue;
		process[current]=true;
		for (auto c:adj[current]){
			int neigh = c.first; ll edge = c.second;
			if (distance[current]+edge<distance[neigh]){
				distance[neigh] = distance[current]+edge;
				pq.push({-distance[neigh],neigh});
				pre[neigh]=current;
			}
		}
		if (current==n){
			break;
		}
	}
	vector<int> path;
	path.pb(n);
	int hold = pre[n];
	while((hold!=-1) & (hold!=0)){
		path.pb(hold);
		hold = pre[hold];
	}
	if (hold==0){ cout << -1;}
	else {
	
	for (int i=path.size()-1;i>=0;i--){
		cout << path[i] << " ";
	}
	}
}
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 